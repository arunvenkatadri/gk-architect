{
  "name": "gk",
  "version": "0.1.0",
  "type": "module",
  "description": "Visual Architecture Builder for Claude Code",
  "license": "MIT",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "node -e \"const p=require('path'),f=p.join('node_modules/electron/dist/Electron.app/Contents/Info.plist');try{let c=require('fs').readFileSync(f,'utf8');c=c.replace(/>Electron</g,'>GK Architect<');require('fs').writeFileSync(f,c)}catch{}\"",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:web": "vite",
    "build": "vite build && electron-builder",
    "build:web": "vite build",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "build:linux": "vite build && electron-builder --linux",
    "rebuild": "bash scripts/rebuild-pty.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.4.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.0",
    "electron-rebuild": "^3.2.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.extelligence.gk-architect",
    "productName": "GK Architect",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": ["nsis", "portable"]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
